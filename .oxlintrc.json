{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["typescript", "react"],
  "categories": {
    "correctness": "error"
  },
  "rules": {
    "no-console": "off",
    "no-debugger": "error",
    "no-unused-vars": ["warn", { "argsIgnorePattern": "^_" }],
    "typescript/no-explicit-any": "error"
  },
  "ignorePatterns": [
    "node_modules",
    "dist",
    "site-dist",
    "storybook-static",
    "coverage",
    "playwright-report",
    "test-results",
    "*.d.ts"
  ],
  "env": {
    "builtin": true,
    "browser": true,
    "node": true,
    "vitest": true
  }
}
