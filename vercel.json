{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build:deploy",
  "outputDirectory": "site-dist",
  "framework": null,
  "redirects": [
    {
      "source": "/",
      "has": [{ "type": "host", "value": "swimmer-ui-storybook.pieaistudio.com" }],
      "destination": "/storybook/",
      "permanent": false
    }
  ]
}
